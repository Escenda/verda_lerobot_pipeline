# Example .env for LeRobot training on Verda spot instances

# =====================
# Hugging Face Hub auth
# =====================
# Personal access token with at least "read" on datasets and "write" on model repos.
# This will be mapped automatically to HF_TOKEN / HUGGING_FACE_HUB_TOKEN on the remote side.
HUGGINGFACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxx

# =====================
# LeRobot dataset / policy
# =====================
# Private dataset already uploaded to the Hugging Face Hub
LEROBOT_DATASET_REPO_ID=your-username/your-private-dataset

# Which policy to train (ACT is the common default)
LEROBOT_POLICY_TYPE=act
# Optional: use a pretrained checkpoint as the starting point (e.g., SmolVLA base)
#LEROBOT_POLICY_PATH=lerobot/smolvla_base

# Job name and output directory (relative to the working dir on the remote machine)
LEROBOT_JOB_NAME=act_private_dataset
# If omitted, OUTPUT_DIR defaults to: outputs/train/{POLICY_TYPE}_{basename(DATASET_REPO_ID)}
LEROBOT_OUTPUT_DIR=outputs/train/act_private_dataset

# Optional: where to push the final policy weights for inference (model repo)
# If omitted, the script will disable automatic push_to_hub.
#LEROBOT_POLICY_REPO_ID=your-username/act_private_dataset_policy

# Optional: rename_map for datasets whose camera keys differ from policy expectations (JSON string)
# Example for SmolVLA: overhead->camera1, wrist->camera2
#LEROBOT_RENAME_MAP={"observation.images.overhead": "observation.images.camera1", "observation.images.wrist": "observation.images.camera2"}

# Optional: number of missing cameras to fill with dummy frames (used with SmolVLA when you have fewer cameras)
#LEROBOT_POLICY_EMPTY_CAMERAS=1

# Optional: install PyTorch nightly cu128 wheels (e.g., for B200/sm_100 GPUs)
#LEROBOT_TORCH_NIGHTLY=1

# Optional: training length (number of gradient steps)
#LEROBOT_STEPS=200000

# Optional: batch size for training
#LEROBOT_BATCH_SIZE=64

# =====================
# Checkpoint persistence across spot instances
# =====================
# If you set this, the remote script will, after each successful run,
# upload the latest "last" checkpoint (including optimizer state) to this model repo.
# You can later resume from this repo_id using the "resume" subcommand.
# Example repo layout on the Hub after upload:
#   pretrained_model/train_config.json
#   pretrained_model/model.safetensors
#   training_state/*.safetensors, training_step.json, ...
#
#LEROBOT_CHECKPOINT_REPO_ID=your-username/lerobot-checkpoint-private-dataset

# =====================
# Weights & Biases (wandb)
# =====================
# API key and project information. wandb.enable is controlled via LEROBOT_WANDB_ENABLE.
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_PROJECT=lerobot-training
WANDB_ENTITY=your-wandb-entity

# Enable/disable wandb logging in LeRobot (true / false)
LEROBOT_WANDB_ENABLE=true
