# Example .env (local only) for Verda/DataCrunch SDK auth and optional defaults

# =====================
# Verda (DataCrunch) API auth
# =====================
# Required locally to create/cleanup instances via the SDK.
DATACRUNCH_CLIENT_ID="your-client-id"
DATACRUNCH_CLIENT_SECRET="your-client-secret"

# =====================
# Local defaults (optional)
# =====================
# Default SSH key names/paths you pass via CLI (optional)
#VERDA_SSH_KEY_NAME="your-verda-ssh-key-name"
#VERDA_SSH_PRIVATE_KEY="~/.ssh/id_ed25519"

# Remote training settings now live in .env.remote.example
